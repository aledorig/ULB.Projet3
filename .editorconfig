root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.json]
indent_style = space
indent_size = 2

[*.toml]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.gdscript]
indent_style = tab
indent_size = 2
max_line_length = 100

[*.gdshader]
indent_style = tab
indent_size = 2
max_line_length = 100

[*.rs]
indent_style = space
indent_size = 4
max_line_length = 100

[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
max_line_length = off
